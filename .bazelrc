# Sipi Bazel configuration — pinned to Bazel 9.0.2 LTS (.bazelversion).
#
# Defaults in Bazel 9 (do NOT re-declare):
#   --enable_bzlmod                          (default in 9)
#   --incompatible_enable_cc_toolchain_resolution  (default in 9)
#
# Kept here as a documented cache-hygiene anchor — strict action env stops
# unrelated host env vars (e.g. GitHub-injected GITHUB_RUN_ID) from poisoning
# Bazel's cache keys across CI runs.
build --incompatible_strict_action_env

# Force the resolved toolchain (toolchains_llvm in MODULE.bazel) instead of
# Bazel's autodetected host C++ toolchain. Without this, Bazel can fall back
# to the host clang/gcc when toolchain resolution misfires, which silently
# breaks hermeticity.
build --action_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1

# Inherit PATH from the invocation environment. `--incompatible_strict_action_env`
# above otherwise rebuilds PATH from a small allow-list (`/bin:/usr/bin:/usr/local/bin`),
# which omits the Nix dev-shell's `/nix/store/…/bin` entries. Several
# foreign_cc rules (libmagic's `autoreconf -fi`, openssl's `perl Configure`)
# need `autoconf` / `automake` / `libtoolize` / `perl` from the dev shell —
# all of which Nix installs into store paths only. Inheriting PATH lets
# those tools through without scattering toolchain paths across the action's
# env. flake.nix ensures the relevant host tools are in the dev-shell PATH.
build --action_env=PATH

# Inherit ACLOCAL_PATH alongside PATH. Nix's `autoconf` / `automake` /
# `libtool` packages each install their m4 macros (`libtool.m4`, `ltversion.m4`,
# automake's own helper macros) under per-package prefixes; the dev shell
# composes them into `ACLOCAL_PATH`. Without that env var, libmagic's
# `autoreconf -fi` preflight fails with `Libtool library used but
# 'LIBTOOL' is undefined` because aclocal can't locate libtool's macros.
build --action_env=ACLOCAL_PATH

# Inherit NIX_LDFLAGS so the Nix-wrapped `clang++` on PATH can find the
# C++ standard library at link time. The wrapper reads NIX_LDFLAGS and
# prepends its -L paths to the linker invocation; without it, kakadu's
# foreign_cc sub-make links libkdu_v85R.so via clang++ which auto-adds
# `-lc++`, but ld.bfd can't find libc++.so anywhere (it lives at
# `/nix/store/…-libcxx-19.1.7/lib/libc++.so` — not on any default search
# path). Toolchains_llvm's own clang doesn't read NIX_LDFLAGS, so this
# is a no-op for Bazel-driven cc actions; it only affects Nix-wrapped
# tools spawned by foreign_cc rules. Required on Linux; harmless on
# macOS (system libc++ at /usr/lib/ resolves without env help).
build --action_env=NIX_LDFLAGS

# Stamp inputs for reproducible binaries and OCI images. The script writes
# STABLE_GIT_COMMIT, STABLE_GIT_VERSION, STABLE_IMAGE_CREATED, and
# STABLE_SIPI_VERSION (sourced from version.txt) — consumed by
# expand_template(..., stamp_substitutions = {...}) in src/BUILD.bazel.
build --workspace_status_command=tools/workspace_status.sh

# Auto-apply :macos / :linux config blocks below by detected host platform.
build --enable_platform_specific_config

# C++23 — same target as the existing CMake build (see CLAUDE.md
# "Compiler Requirements: C++23").
build --cxxopt=-std=c++23
build --host_cxxopt=-std=c++23

# ── Hardening neutralization ───────────────────────────────────────────────
# Mirrors flake.nix `hardeningDisable = [ "all" ]`. Bazel's foreign_cc deps
# (libtiff, exiv2, openssl, …) and Sipi's own code build today against a
# stack stripped of nixpkgs' default hardening; keep parity here so Bazel
# binaries match the Nix-built ones byte-for-byte where possible. PIE
# specifically is required-on for macOS, so the -fno-pie/-no-pie pair is
# scoped to Linux only.
build --copt=-U_FORTIFY_SOURCE
build --copt=-fno-stack-protector
build --host_copt=-U_FORTIFY_SOURCE
build --host_copt=-fno-stack-protector

build:linux --copt=-fno-stack-clash-protection
build:linux --copt=-fno-pie
build:linux --linkopt=-no-pie
build:linux --host_copt=-fno-stack-clash-protection
build:linux --host_copt=-fno-pie
build:linux --host_linkopt=-no-pie

# ── macOS ──────────────────────────────────────────────────────────────────
# Pin the deployment target so Bazel-built binaries are portable across
# macOS releases. Required because toolchains_llvm does not bundle a macOS
# sysroot — the Xcode CLT SDK is consulted at build time and its default
# version is whatever shipped with the host OS.
#
# 13.3 is the floor: Apple's libc++ marks `std::bad_expected_access`
# (and the rest of the C++23 `<expected>` machinery's vtables/typeinfo)
# as available from macOS 13.3 onwards. With the previous 12.0 pin,
# linking sipi failed with `ld64.lld: error: undefined symbol: vtable
# for std::__1::bad_expected_access<void>` because SipiHttpServer.cpp
# uses `std::expected` per the C++23 style guide. The CMake build path
# escapes this because it inherits the SDK default (whatever shipped
# with the host's Xcode CLT) instead of explicitly pinning low.
build:macos --copt=-mmacosx-version-min=13.3
build:macos --linkopt=-mmacosx-version-min=13.3
build:macos --host_copt=-mmacosx-version-min=13.3
build:macos --host_linkopt=-mmacosx-version-min=13.3
build:macos --action_env=MACOSX_DEPLOYMENT_TARGET=13.3

# Use Apple SDK's libc++ for compile AND link, instead of LLVM 19.1.7's
# bundled libc++ headers + Apple SDK libc++.dylib. Without this, clang
# emits ABI-tagged symbols against its bundled headers (e.g.
# `std::__1::bad_expected_access<void>::bad_expected_access[abi:ne190107]`)
# but ld64.lld links against `/usr/lib/libc++.dylib` which has Apple's
# different ABI tags — final sipi link fails with `undefined symbol:
# vtable for std::__1::bad_expected_access<void>`.
#
# `-nostdinc++` strips clang's bundled C++ stdlib include path; the
# explicit `-isystem` pointing at the Xcode CLT SDK's `c++/v1` directory
# adds Apple's libc++ headers back. The link automatically picks Apple's
# libc++.dylib via `-isysroot` (which toolchains_llvm sets from
# DEVELOPER_DIR/SDKROOT), so compile + link agree on ABI.
#
# Mirrors the existing CMake build's behavior — Apple's clang from
# `/Library/Developer/CommandLineTools` uses Apple's libc++ throughout,
# so the macOS dev path is consistent across both toolchains.
build:macos --copt=-nostdinc++
build:macos --copt=-isystem/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/usr/include/c++/v1
build:macos --host_copt=-nostdinc++
build:macos --host_copt=-isystem/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/usr/include/c++/v1

# Force toolchains_llvm to resolve the macOS SDK against the system Xcode
# Command Line Tools rather than nixpkgs' stripped-down `apple-sdk-14.4`
# (`/nix/store/…-apple-sdk-14.4`), which only ships private Apple framework
# stubs — no `libc++.tbd`/`libc++abi.tbd` under `usr/lib/`. nix-develop
# inherits `SDKROOT`/`DEVELOPER_DIR` from the host env and prepends
# `xcbuild`'s reimplemented `xcrun` (always pinned to the Nix SDK) to PATH;
# `toolchains_llvm`'s repository rule shells out to `xcrun --show-sdk-path`
# at module-evaluation time and bakes whatever it gets into `cc_wrapper.sh`,
# producing link errors like `ld64.lld: error: library not found for -lc++`.
#
# Overriding via `--repo_env` confines the change to repo rule evaluation —
# build actions still see the user's full env (cmake's nix-wrapped clang
# hardcodes `--sysroot` and ignores SDKROOT, so the inner-loop CMake build
# is unaffected).
#
# `--repo_env=PATH` (no value) inherits PATH from the invocation env. The
# `clang` dev shell in flake.nix prepends `/usr/bin:/bin:/usr/local/bin`
# to PATH on darwin, so toolchains_llvm's `xcrun` probe still finds
# Apple's `/usr/bin/xcrun` first while Nix-only tools (`gh` for
# `kakadu_archive`, `perl`/`autoconf`/`automake`/`libtoolize` for the
# autotools libs) remain reachable for repo-rule script execution.
build:macos --repo_env=PATH
build:macos --repo_env=DEVELOPER_DIR=/Library/Developer/CommandLineTools
build:macos --repo_env=SDKROOT=/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk

# ── Test ───────────────────────────────────────────────────────────────────
# Surface test stderr immediately on failure rather than collecting it into
# bazel-testlogs — useful for inner-loop iteration. CI flips this off.
test --test_output=errors

# ── User overrides ─────────────────────────────────────────────────────────
# Local-machine-only flags (e.g. --disk_cache=...) belong in user.bazelrc;
# the file is gitignored.
try-import %workspace%/user.bazelrc
