# Sipi Bazel configuration — pinned to Bazel 9.0.2 LTS (.bazelversion).
#
# Defaults in Bazel 9 (do NOT re-declare):
#   --enable_bzlmod                          (default in 9)
#   --incompatible_enable_cc_toolchain_resolution  (default in 9)
#
# Kept here as a documented cache-hygiene anchor — strict action env stops
# unrelated host env vars (e.g. GitHub-injected GITHUB_RUN_ID) from poisoning
# Bazel's cache keys across CI runs.
build --incompatible_strict_action_env

# Force the resolved toolchain (the hermetic `llvm` toolchain in MODULE.bazel)
# instead of Bazel's autodetected host C++ toolchain. Without this, Bazel can
# fall back to the host clang/gcc when toolchain resolution misfires, which
# silently breaks hermeticity. (Candidate for removal under the hermetic
# toolchain — a properly registered toolchain shouldn't fall back; left in
# place until the swap is proven green on all platforms, then test-removed.)
build --action_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1

# Inherit PATH from the invocation environment. `--incompatible_strict_action_env`
# above otherwise rebuilds PATH from a small allow-list (`/bin:/usr/bin:/usr/local/bin`),
# which omits the Nix dev-shell's `/nix/store/…/bin` entries. Inheriting PATH
# keeps the dev-shell tools (e.g. `git` for `tools/workspace_status.sh`)
# reachable without scattering toolchain paths across the action's env.
build --action_env=PATH

# Stamp inputs for reproducible binaries and OCI images. The script writes
# STABLE_GIT_COMMIT, STABLE_GIT_VERSION, STABLE_IMAGE_CREATED, and
# STABLE_SIPI_VERSION (sourced from version.txt) — consumed by
# expand_template(..., stamp_substitutions = {...}) in src/BUILD.bazel.
build --workspace_status_command=tools/workspace_status.sh

# Auto-apply :macos / :linux config blocks below by detected host platform.
build --enable_platform_specific_config

# C++23 — same target as the existing CMake build (see CLAUDE.md
# "Compiler Requirements: C++23").
build --cxxopt=-std=c++23
build --host_cxxopt=-std=c++23

# Force static linking for cc_binary / cc_test on Linux. cc_test on
# Linux defaults to dynamic linking, which makes Bazel emit a `.so`
# for every transitive cc_library and links each test against those
# DSOs. That collides with two realities of this build:
#   * the native `cc_library` deps (e.g. exiv2) ship a static `.a` only —
#     Bazel's auto-DSO for `//src:sipi_lib` then references their symbols
#     across a DSO boundary, and the linker rejects them as
#     "non-exported symbol 'Exiv2::…' in libexiv2.a is referenced by
#     DSO libsrc_Slibsipi_Ulib.so".
#   * the hermetic toolchain's `libc++.a` carries non-PIC relocations on
#     aarch64, so even when `.so` linking is otherwise correct, the
#     C++ stdlib pull-in fails with `recompile with -fPIC`.
# Static linking matches `bazel build //src:sipi` (which already
# defaults to static via `cc_binary`'s `linkstatic=True`), so cc_test
# behaves the same way as the production binary it tests against.
# darwin is unaffected: its default is already mostly static.
build:linux --dynamic_mode=off

# `__isoc23_strtol` / `fcntl64` glibc-2.39 → glibc-2.31 aliases are
# provided by `//bazel:glibc23_compat` (Linux-only cc_library, propagated
# via `//src:sipi_lib`'s deps select). The earlier `--linkopt=-Wl,--defsym`
# approach was rejected because `--linkopt` flows into every link
# action where neither side of the alias is yet linked, producing
# `--defsym:1: symbol not found: strtol`.

# ── Hardening (production target binary) ───────────────────────────────────
# Re-enables stack-protector-strong, fortify-source, stack-clash protection,
# and BindNow for the publicly-deployed sipi binary (DEV-6282). PIE/PIC are
# already on by toolchain default since DEV-6348.
#
# Host config is deliberately left unhardened — host-built tools (e.g.
# libmagic's `file` bootstrap that generates magic.mgc, protoc, etc.) are
# never deployment artifacts, and `-D_FORTIFY_SOURCE=2` conflicts with
# libmagic 5.47's `file.h:666` (glibc's `__dprintf_chk` fortified macro vs
# libmagic's own dprintf-related declaration). Hardening host tools adds
# no security value, so the simpler course is to keep host config clean.
#
# Sanitizer (`--config=asan`/`--config=ubsan`) and fuzz (`--config=fuzz`)
# builds keep target hardening off — `_FORTIFY_SOURCE=2` intercepts the
# same libc functions ASan does (memcpy/memmove/etc.), and the
# instrumentation already subsumes the stack canary's intent. The
# per-config overrides further down ensure those compile lines do NOT
# carry the new hardening flags.
build --copt=-fstack-protector-strong
# `_FORTIFY_SOURCE=2` lives in `--config=release` (just below), NOT the global
# `build` config: it requires optimization, so at the default fastbuild `-O0` it
# does nothing but emit a glibc `#warning` on every TU (huge CI log spam).
# Release-only keeps dev / fastbuild / CI builds quiet.
#
# ── Release (production) build config ────────────────────────────────────────
# `--config=release` IS the production build — the Docker image recipes
# (`just bazel-docker-build/push-*`, `bazel-docker-extract-debug`) use it:
# `-c opt` codegen + `_FORTIFY_SOURCE=2` hardening. The hermetic-llvm toolchain's
# opt feature injects `-D_FORTIFY_SOURCE=1`; we undef then redefine to 2
# (undef-then-define avoids `-Wmacro-redefined`). libmagic 5.47 conflicts with the
# fortified glibc headers, so undo FORTIFY for its TUs only (substring match — no
# other source path contains "libmagic"; an anchored `^external/libmagic\+/…$`
# form fails to match in `.bazelrc`, verified via aquery).
build:release --compilation_mode=opt
build:release --copt=-U_FORTIFY_SOURCE
build:release --copt=-D_FORTIFY_SOURCE=2
build:release --per_file_copt=libmagic@-U_FORTIFY_SOURCE

# Linux-only: stack-clash-protection is a clang-on-Linux feature (warns
# harmlessly on a darwin cross-compile). Its companion `-Wl,-z,now` linkopt
# lives in //src:sipi_lib's (and :engine's) target-keyed linkopts select
# instead: a linkopt must key on the TARGET os, not the host, or a Linux-host
# cross-compile to darwin hands `-z` to ld64.lld, which rejects it.
build:linux --copt=-fstack-clash-protection

# ── macOS ──────────────────────────────────────────────────────────────────
# Pin the deployment target so Bazel-built binaries are portable across macOS
# releases. The hermetic `llvm` toolchain fetches the MacOSX26.4 SDK from
# Apple's CDN; a recent SDK otherwise defaults the deployment target high, so
# pin the floor explicitly. 13.3 is retained from the toolchains_llvm era (the
# floor at which Apple's libc++ marked the C++23 `<expected>` machinery
# available) and remains a safe minimum under hermetic-llvm's own libc++.
build:macos --copt=-mmacosx-version-min=13.3
build:macos --linkopt=-mmacosx-version-min=13.3
build:macos --host_copt=-mmacosx-version-min=13.3
build:macos --host_linkopt=-mmacosx-version-min=13.3
build:macos --action_env=MACOSX_DEPLOYMENT_TARGET=13.3

# Inherit PATH during repo-rule evaluation on macOS so the Kakadu
# `gh_release_archive` fetch (needs `gh` from the Nix dev shell) stays
# reachable. hermetic-llvm manages its own libc++ and fetches the SDK from
# Apple's CDN, so no SDK/xcrun env overrides are needed.
build:macos --repo_env=PATH

# Force `rules_android`'s `android_sdk_repository_extension` to take the
# empty-SDK branch instead of validating an actual Android SDK install.
# `rules_android` is pulled transitively by `protobuf` (BCR) and its
# `@androidsdk//:all` toolchain registration runs at toolchain-resolution
# time for *every* target — even pure C++ ones. The extension reads
# `ANDROID_HOME` and fails with "No Android SDK apis found …" when the
# path exists but has no `platforms/android-XX` subdirs. GitHub Actions
# runners pre-set `ANDROID_HOME=/usr/local/lib/android/sdk` (Linux) or
# `/Library/Android/sdk` (macOS) without populated platforms, so the
# check tanks every CI build until we explicitly clear it for Bazel.
#
# The bypass is in rules_android 0.7.x's
# `_android_sdk_repository_impl`: an unset/empty `ANDROID_HOME` falls
# through to the empty-SDK template path (`return None`), satisfying
# the toolchain registration without requiring real Android tooling.
# Local dev with a real Android SDK is unaffected — devs don't typically
# set ANDROID_HOME for SIPI work, and if they do they can override on
# the command line.
common --repo_env=ANDROID_HOME=

# ── Sanitizers — opt-in via --config=asan and/or --config=ubsan ─────────────
# Replaces the deleted `.#sanitized` Nix variant. CI's sanitizer.yml uses
# both together via `just bazel-build-sanitized`
# (`bazel build --config=asan --config=ubsan //src:sipi`); the e2e step then
# runs the suite against `bazel-bin/src/sipi` with `.lsan_suppressions.txt`
# and `ASAN_OPTIONS=log_path=/tmp/asan-e2e`. The two configs are kept
# separate so a developer can isolate a finding to ASan vs UBSan.
#
# `--compilation_mode=dbg` matches the prior Nix variant's `Debug` cmake
# build and gives us `-g -O0` (clearer ASan stack traces and no compiler
# elision of UBSan checks); `--strip=never` keeps DWARF inline so LSan's
# symbol-name suppressions (`leak:lua*` in `.lsan_suppressions.txt`)
# actually match — the same invariant the old override enforced via
# `dontStrip = true` + `separateDebugInfo = false`.
#
# **Instrumentation via the toolchain's `--@llvm//config:{asan,ubsan}`
# flags** (DEV-6563 Phase 12). Setting `--@llvm//config:asan=true` makes
# the hermetic-llvm toolchain (a) add `-fsanitize=address` to every
# target compile + link, (b) put the compiler-rt `sanitizer/*.h` headers
# on the include path (abseil's `dynamic_annotations.h` includes
# `sanitizer/common_interface_defs.h` whenever ASan is active), and
# (c) build + link the compiler-rt ASan runtime from source. The three
# are bundled in the one flag — the toolchain has no "provide the runtime
# but let me scope the instrument myself" knob. ADR-0014 carved this gate
# out precisely because the minimal prebuilt shipped no runtime;
# foreign_cc=0 (ADR-0015) then removed the global-instrument blocker
# (no CMake compiler-detection links left to break), so the toolchain
# flag is now the supported re-arm path. `--config=ubsan` is the same
# shape (`-fsanitize=undefined` + the toolchain's own ignorelist).
#
# This instruments the native deps (kakadu / libtiff / openssl / …) too,
# not only first-party code — broader than the old `--per_file_copt`
# scoping, which the toolchain cannot reproduce (provisioning the runtime
# forces the global flag). For a sanitizer *gate* that is strictly more
# coverage (it catches memory errors in how sipi drives the deps); the
# cost is a from-scratch instrumented build (compiler-rt from source +
# every dep), amortised by the remote cache. The vptr check now links
# cleanly — hermetic-llvm builds + statically links `libubsan_standalone`
# (incl. the C++ runtime) from source, so the old `-fno-sanitize=vptr`
# workaround (toolchains_llvm shipped only the dynamic ubsan-cxx runtime)
# is gone. Darwin remains unsupported (the macOS toolchain args omit the
# sanitizer header path); the gate runs on linux-x86_64.

# Neutralize the production hardening flags (`build --copt=…` block above)
# for sanitizer builds. `_FORTIFY_SOURCE=2` intercepts the same libc
# functions ASan does (memcpy/memmove/etc.), causing duplicate-symbol or
# poisoned-memory conflicts; stack-protector is subsumed by ASan's
# stack-frame redzones. The `--copt` flags below are appended AFTER the
# global `build --copt=…` block, and the compiler's "last wins" precedence
# (for `-U_FORTIFY_SOURCE` after `-D_FORTIFY_SOURCE=2`, and
# `-fno-stack-protector` after `-fstack-protector-strong`) yields a clean
# un-hardened compile line. Verified via
#   bazel aquery --config=asan 'mnemonic("CppCompile", //src/cli:sipi)'
# 2026-05-26.
build:asan --copt=-U_FORTIFY_SOURCE
build:asan --copt=-fno-stack-protector
build:asan --compilation_mode=dbg
build:asan --strip=never
build:asan --@llvm//config:asan=true

# ASan runtime env for `bazel test --config=asan`.
# `log_path=$TEST_UNDECLARED_OUTPUTS_DIR/asan-e2e` lands findings under
# `bazel-testlogs/<pkg>/<target>/test.outputs/asan-e2e.<pid>` — the
# directory is Bazel-guaranteed inside test actions and is automatically
# uploaded as a test-output artefact. `sanitizer.yml` greps for
# `SUMMARY:` lines under that glob.
#
# `detect_leaks=1` keeps LSan on; `halt_on_error=0` lets a test surface
# every leak in one report rather than needing N reruns.
test:asan --test_env=ASAN_OPTIONS=detect_leaks=1:halt_on_error=0:log_path=$TEST_UNDECLARED_OUTPUTS_DIR/asan-e2e

# Neutralize production hardening for UBSan — same rationale as `build:asan`.
build:ubsan --copt=-U_FORTIFY_SOURCE
build:ubsan --copt=-fno-stack-protector
build:ubsan --compilation_mode=dbg
build:ubsan --strip=never
build:ubsan --@llvm//config:ubsan=true

# ── Fuzz harness — opt-in via --config=fuzz ────────────────────────────────
# Replaces the deleted `.#fuzz` Nix variant. CI's `fuzz.yml` workflow
# consumes it via `just bazel-build-fuzz` and `just bazel-run-fuzz
# <corpus> <duration> <seed>`.
#
# `--platforms=//tools/fuzz:<host>_fuzz` is set by the justfile recipes
# based on `uname`. The platform carries `//tools/fuzz:fuzz_enabled`,
# which activates the `target_compatible_with` gate on
# `//fuzz/handlers:iiif_handler_uri_parser_fuzz` (it builds under
# `--config=fuzz`, skips analysis otherwise). A single hermetic LLVM
# toolchain (libc++) serves both the normal and the fuzz build.
#
# Instrumentation + runtimes come from the toolchain's own sanitizer
# flags — same mechanism as `build:asan` above (DEV-6563 Phase 13):
#   * `--@llvm//config:fuzzer=true` — `-fsanitize=fuzzer` on every target
#     compile (libFuzzer coverage: trace-pc-guard / trace-cmp / …) and
#     link, and builds + links the compiler-rt **libFuzzer runtime** from
#     source (the runtime ADR-0014 carved this gate out for).
#   * `--@llvm//config:asan=true` — ASan instrumentation + runtime, which
#     the harness has always carried alongside libFuzzer.
# These are global (every reachable dep instrumented), not the old
# first-party `--per_file_copt` scoping — the toolchain bundles runtime
# provisioning with the global flag and exposes no runtime-only knob. The
# fuzz binary's reachable graph is just `//src/shttps:fuzz_subset`
# (+ curl / jansson / libmagic / lua / openssl / sqlite3 / zlib), so the
# coverage map stays bounded. libFuzzer supplies the binary's `main()`;
# only that one `cc_binary` is built under `--config=fuzz`, so the global
# `-fsanitize=fuzzer` link flag never reaches a production binary.
#
# **linux-x86_64 only.** Darwin is gapped under hermetic-llvm, on two
# layers: (1) the macOS toolchain args omit the sanitizer header/runtime
# wiring the Linux args carry (`undefined symbol: __asan_init`), and (2)
# even once that is patched in, building the darwin compiler-rt sanitizer
# runtimes from source hits an upstream Bazel-sandbox bug ("Could not copy
# inputs into sandbox: compiler-rt/include (File exists)"). The module README
# flags non-Linux sanitizer support as WIP. `bazel-build-fuzz` still selects
# `darwin_aarch64_fuzz` locally but will not link until both close upstream;
# the CI gate is linux-x86_64 regardless. See the `build:asan` note.
#
# Neutralize production hardening for fuzz — same rationale as `build:asan`.
build:fuzz --copt=-U_FORTIFY_SOURCE
build:fuzz --copt=-fno-stack-protector
build:fuzz --@llvm//config:fuzzer=true
build:fuzz --@llvm//config:asan=true

# ── Tracy profiler — opt-in via --config=tracy ─────────────────────────────
# Local-dev only, never CI-gated (like `just bench` / `just valgrind`).
# `just bazel-build-tracy` adds `-c opt` and builds //src/cli:sipi; run the
# binary and connect the Tracy GUI over TCP 8086. The `@tracy//:tracy` dep is
# always in the graph but inert until TRACY_ENABLE is defined here, so these
# flags are the *only* thing that arms the profiler.
#
#   * TRACY_ENABLE   — master switch. Defined globally so it reaches both
#     TracyClient.cpp and every instrumented first-party TU (the zone macros in
#     `src/observability/profiling.h` are no-ops without it).
#   * TRACY_ON_DEMAND — a long-running server must not buffer profiling data
#     when no GUI is attached; with this, collection starts only on connect.
#   * -fno-omit-frame-pointer + -g + --strip=never — symbol-accurate zones and
#     enable Tracy's statistical call-stack sampling alongside the manual zones.
build:tracy --copt=-DTRACY_ENABLE
build:tracy --copt=-DTRACY_ON_DEMAND
build:tracy --copt=-fno-omit-frame-pointer
build:tracy --copt=-g
build:tracy --strip=never
# Tracy's headers (pulled into instrumented first-party TUs via profiling.h) trip
# -Wthread-safety-analysis on their lock-free queue internals. Vendored code we
# don't maintain; silence it for this dev-only config (the warning still applies
# to first-party code in the normal/sanitizer builds).
build:tracy --copt=-Wno-thread-safety-analysis

# ── Test ───────────────────────────────────────────────────────────────────
# Surface test stderr immediately on failure rather than collecting it into
# bazel-testlogs — useful for inner-loop iteration. CI flips this off.
test --test_output=errors

# Retry the timing-sensitive e2e tests up to 3x — the single retry mechanism
# for the suite (replaces the bespoke Rust `retry_flaky` helper / inline poll
# loops, removed in favour of Bazel's native `--flaky_test_attempts`). These
# six assert on server-side timing the test can't pin down deterministically:
#   - latency / iiif_compliance / resource_limits: connection / cache budgets a
#     loaded CI runner (observed on linux-arm64) blows on a single attempt —
#     surfacing as a transient `hyper::Error(IncompleteMessage)`.
#   - memory_budget / resource_limits: an eventually-consistent state settling
#     just after the response (the decode-budget gauge returning to 0; the musl
#     binary recovering after a heavy transform pipeline).
#   - server: lua_test_functions / lua_uuid_round_trip intermittently 503 under
#     suite-load bursts when the engine-pool semaphore sheds (routes.rs
#     `try_acquire_owned`); the deterministic 503 cases in `server` are
#     `#[ignore]`'d (plan 02 §8.1, DEV-6659), so only this transient residue
#     remains here. Root cause to revisit in the cluster-A concurrency work.
#   - upload: concurrent_file_uploads' post-burst responsiveness probe 503s when
#     the upload burst's permits have not yet been released (same engine-pool
#     semaphore; passes 3/3 in isolation, sheds only under parallel-suite load).
# A genuinely broken test still fails all 3 attempts, so this masks flakes, not
# regressions. `--flaky_test_attempts` is `accumulate_value` (one entry per
# target) and matches the target label as a regex; a no-op for invocations that
# don't include the target. Living in `.bazelrc` (not a per-workflow flag)
# means ci.yml, sanitizer.yml, and local `just bazel-test` all inherit it —
# single source of truth (sanitizer.yml carries no inline retry flags of its own).
test --flaky_test_attempts=//test/e2e:latency@3
test --flaky_test_attempts=//test/e2e:iiif_compliance@3
test --flaky_test_attempts=//test/e2e:resource_limits@3
test --flaky_test_attempts=//test/e2e:memory_budget@3
test --flaky_test_attempts=//test/e2e:server@3
test --flaky_test_attempts=//test/e2e:upload@3

# ── Remote build execution (NativeLink VM) ──────────────────────────────────
# The self-hosted NativeLink VM is the Bazel backend: Remote Cache + Remote
# Execution (:50051, mTLS) plus a co-located bazel-remote (:50052) as the
# http_archive download cache. The connection + mTLS flags are built by the
# `bazel-rbe` composite action and injected per CI step (Bazel does NOT expand
# env vars in .bazelrc, so they live in the workflow, not here):
#   --remote_cache / --remote_executor=grpcs://<vm>:50051
#   --experimental_remote_downloader=grpcs://<vm>:50052
#   --tls_certificate / --tls_client_certificate / --tls_client_key
# Local dev never sets those, so the tuning flags below are safe no-ops without a
# remote configured.
#   --remote_download_minimal: only fetch outputs of explicitly-built targets;
#     intermediate action outputs stay in the CAS (build-without-the-bytes).
#   --remote_local_fallback: if the VM is unreachable, build locally instead of
#     failing — a VM outage degrades wall-clock, never breaks CI.
#   --remote_timeout=600s: per-request budget sized for cold native-dep compiles
#     on the worker (far longer than a cache-only round-trip).
#   --remote_max_connections=100: raises the gRPC parallelism ceiling for fast
#     bulk lookup at build-graph evaluation time.
# No --remote_cache_compression: NativeLink v1.5.2 does not advertise wire
# compression, so enabling it fails the capabilities query.
build --remote_download_minimal
build --remote_local_fallback
build --remote_timeout=600s
build --remote_max_connections=100

# BCR curl ships with three configurable TLS backends (boringssl default,
# mbedtls, openssl) selected via a `string_flag`. Pin to `openssl` so the
# resolved cc dep is `@openssl//:{ssl,crypto}` rather than BoringSSL —
# sipi's `src/shttps/jwt/jwt.c` calls OpenSSL 3.x APIs (`EVP_PKEY_get_int_param`
# etc.) that BoringSSL doesn't expose, and a mixed include path causes
# the BoringSSL `openssl/evp.h` to shadow the real OpenSSL header.
build --@curl//:ssl_lib=openssl

# ── User overrides ─────────────────────────────────────────────────────────
# Local-machine-only flags (e.g. --disk_cache=...) belong in user.bazelrc;
# the file is gitignored.
try-import %workspace%/user.bazelrc
