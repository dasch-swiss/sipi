"""Sipi — IIIF-compatible media server.

Bazel 9.0.2 LTS module. Bazel is the build system; Nix provisions the
dev shell only.

Versioning: `version.txt` is the single source of truth for the Sipi version
string. `tools/workspace_status.sh` reads it into `STABLE_SIPI_VERSION`, which
`expand_template` substitutes into `include/SipiVersion.h.in`. The `version`
attribute below is intentionally left at the placeholder "0.0.0" — Sipi is not
published to the Bazel Central Registry, so this string is never consumed by a
downstream module.
"""

module(
    name = "sipi",
    version = "0.0.0",
    compatibility_level = 1,
)

# ── Foundational rules ────────────────────────────────────────────────────
# `platforms` declares the OS/CPU pairs `//platforms:*` resolves against;
# `rules_cc` is required at the top of every BUILD.bazel using cc_* in
# Bazel 9 (built-in cc_* rules removed from the global namespace).
bazel_dep(name = "platforms", version = "1.0.0")
bazel_dep(name = "rules_cc", version = "0.2.18")

# `aspect_bazel_lib` provides `expand_template` with `stamp_substitutions=`,
# which Y consumes to bake `STABLE_SIPI_VERSION` etc. into SipiVersion.h.
# Y+4 will reuse it for OCI image stamping (`image_created`, `image_labels`).
bazel_dep(name = "aspect_bazel_lib", version = "2.22.5")

# `rules_foreign_cc` wraps the 20 remaining third-party libs (cmake/,
# configure_make/, make/) — see ext/<lib>/BUILD.bazel files. Pinned
# versions are declared via http_archive() calls in this file. Two libs
# that historically lived under foreign_cc are no longer in the set:
# `prometheus-cpp` (now consumed via the BCR `bazel_dep` below) and `fmt`
# (dead dep — see comment in the http_archive section).
bazel_dep(name = "rules_foreign_cc", version = "0.15.1")

# `prometheus-cpp` consumed via the BCR module rather than the foreign_cc
# `cmake()` wrapper used for the remaining third-party libs. SIPI only
# links the core counters/gauges/histograms (no HTTP exposer — metrics are
# served by SIPI's own shttps handler), so `@prometheus_cpp//core` is the
# only target consumed; the BCR module's optional `pull`/`push`/`civetweb`
# subgraphs stay outside the action graph. Version `1.3.0.bcr.2` is the
# BCR re-pack of upstream `v1.3.0` — same source, no upstream bump.
# `repo_name = "prometheus_cpp"` (underscore) keeps consumer BUILDs short
# vs. the BCR canonical `com_github_jupp0r_prometheus_cpp`.
bazel_dep(name = "prometheus-cpp", version = "1.3.0.bcr.2", repo_name = "prometheus_cpp")

# Surgical fix for the BCR repack: upstream `core/BUILD.bazel` uses bare
# `cc_library(...)` without a `load()`, which Bazel 9 rejects (the legacy
# global cc rules were removed). The BCR module only patches MODULE.bazel,
# not the BUILD files. Patching here — instead of enabling
# `--incompatible_autoload_externally=+cc_library` project-wide — keeps
# the explicit-load discipline intact for our own first-party BUILDs.
# `patch_strip = 1` matches the conventional `a/`/`b/` prefixes in the
# diff. Drop this `single_version_override` when prometheus-cpp publishes
# a Bazel-9-clean BCR rev (the patch will fail loudly when the upstream
# file shape changes — desired feedback).
single_version_override(
    module_name = "prometheus-cpp",
    patch_strip = 1,
    patches = ["//bazel/patches:prometheus_cpp_load_cc.patch"],
)

# `protobuf` consumed via BCR (DEV-6410 / ADR-0005). The Essentials packet
# (`src/metadata/essentials.proto`) uses `optimize_for = LITE_RUNTIME`, so only
# the protobuf-lite static archive enters the link (≈300-500 KB).
# `proto_library` and `cc_proto_library` are exported by the protobuf module
# itself (`@com_google_protobuf//bazel:{proto_library,cc_proto_library}.bzl`)
# in protobuf 26+. `repo_name = "com_google_protobuf"` matches the canonical
# name any future Rust IIIF service in dsp-repository will share via the BCR.
bazel_dep(name = "protobuf", version = "34.1", repo_name = "com_google_protobuf")

# protobuf 34.1 transitively pulls `rules_go@0.51.0-rc2` for its Go support.
# That release's `go/private/rules/cgo.bzl` still references `CcInfo` from
# `@rules_cc//cc:defs.bzl`, where the symbol was removed in rules_cc 0.2.x
# (now `@rules_cc//cc/common:cc_info.bzl`). Bazel resolves the registered
# `@go_toolchains//:all` toolchain at analysis time even for non-Go targets,
# so the broken load fires on first `bazelisk build //src/metadata:essentials_cc_proto`.
# Override to the latest stable rules_go, which loads CcInfo from the new path.
# Drop this override once a protobuf release pins a Bazel-9-clean rules_go.
bazel_dep(name = "rules_go", version = "0.60.0")

# Same story for `rules_android` — protobuf 34.1 transitively pulls
# `rules_android@0.6.4`, whose `android_local_test/attrs.bzl` still loads
# `CcInfo` from `@rules_cc//cc:defs.bzl`. Bazel resolves the registered
# `@androidsdk//:all` toolchain at analysis time for every target's
# toolchain query (even pure C++ ones), so the broken load tanks every
# `bazel build` / `bazel test` on CI runners that lack an Android SDK
# install. rules_android 0.7.x loads CcInfo from the new path and no
# longer eagerly fails when ANDROID_HOME is unset. Drop this override
# once protobuf bumps to a rules_android that's clean on Bazel 9.
single_version_override(
    module_name = "rules_android",
    version = "0.7.2",
)

# `toolchains_llvm` registers a hermetic LLVM 19.1.x toolchain. Sysroot wiring
# (Chromium debian sysroots for linux-x86_64 / linux-aarch64) lives below.
# macOS uses the system Xcode CLT SDK (no bundled macOS sysroot in
# toolchains_llvm); MACOSX_DEPLOYMENT_TARGET=12.0 is pinned in .bazelrc.
bazel_dep(name = "toolchains_llvm", version = "1.7.0")

# ── Container image rules ─────────────────────────────────────────────────
# `rules_oci` builds the OCI image. The image is assembled per-arch by
# `oci_image`, pushed by `oci_push`; the multi-arch manifest is built by
# `crane index append` on a coordinator job (NOT `oci_image_index`, which
# only consumes same-build-graph labels — per-arch CI runners produce
# digests that cross job boundaries).
#
# `rules_oci` 2.x maintainer CI does not yet list Bazel 9 as tested;
# community reports indicate it works. If a Bazel-9 incompat surfaces, the
# fallback is a `genrule` that subprocesses `crane append` directly (same
# multi-arch architecture, fewer rules-set deps).
bazel_dep(name = "rules_oci", version = "2.3.0")

# `rules_distroless` provides `passwd()` and `group()` macros for
# fakeNss-equivalent /etc/passwd + /etc/group + nsswitch.conf layers
# (replaces today's `dockerTools.fakeNss`). See `//src:nss_layer`.
bazel_dep(name = "rules_distroless", version = "0.8.0")

# `tar.bzl` provides the `tar()` rule used to assemble runtime layers
# (sipi binary wrapper layout, sipi config/scripts/server tree, nsswitch
# layer). Deterministic by construction (sorted entries, mtime=0,
# uid/gid=0) — required for OCI tarball SHA reproducibility.
bazel_dep(name = "tar.bzl", version = "0.10.4")

# `oci_pull` for the distroless_base image used as `:image`'s base layer.
# Pinned by `digest =`, never `tag =` (reproducibility-critical: tags
# float; digests don't). Multi-arch index — `rules_oci`'s platform-aware
# resolution selects amd64 or arm64 manifest at build time. The digest
# below was captured 2026-05-08 from
#   curl -sSL https://gcr.io/v2/distroless/base-debian12/manifests/latest \
#     -H 'Accept: application/vnd.oci.image.index.v1+json'
# Bumping it later means re-running the curl and copying the
# `Docker-Content-Digest` response header.
oci = use_extension("@rules_oci//oci:extensions.bzl", "oci")
oci.pull(
    name = "distroless_base",
    digest = "sha256:9dce90e688a57e59ce473ff7bc4c80bc8fe52d2303b4d99b44f297310bbd2210",
    image = "gcr.io/distroless/base-debian12",
    platforms = [
        "linux/amd64",
        "linux/arm64/v8",
    ],
)
use_repo(oci, "distroless_base", "distroless_base_linux_amd64", "distroless_base_linux_arm64_v8")

# `apt.install` resolves Debian bookworm package dependencies from the
# manifest in `bazel/distroless/bookworm.yaml` against the lock file in
# `bookworm.lock.json`. The lock file is regenerated by:
#
#     bazel run @bookworm//:lock
#
# Provides the runtime extras the production image needs alongside
# `distroless_base-debian12`'s glibc + ca-certificates + tzdata + openssl:
#
#   - tini:  `/usr/bin/tini`     PID 1 zombie reaping + signal forwarding
#                                (entrypoint `["tini", "--", "/sbin/sipi"]`).
#   - curl:  `/usr/bin/curl`     Used by ops-deploy's compose-level
#                                healthcheck — `CMD curl -sf
#                                http://localhost:1024/health`.
#
# Snapshot pin: snapshot.debian.org timestamp freezes Debian's apt index
# so the lock file is reproducible across runs. Bumping the snapshot
# means re-running `bazel run @bookworm//:lock` and committing the
# updated `bookworm.lock.json`.
apt = use_extension("@rules_distroless//apt:extensions.bzl", "apt")
apt.install(
    name = "bookworm",
    lock = "//bazel/distroless:bookworm.lock.json",
    manifest = "//bazel/distroless:bookworm.yaml",
)
use_repo(apt, "bookworm")

# `http_archive` is also used (later in this file) for `ext/<lib>/`
# foreign_cc archive ingest, but those entries are below the LLVM
# toolchain block. We need it available here for the FFmpeg static
# pull, so bind it once now — `use_repo_rule` may be called multiple
# times for the same upstream rule.
http_archive = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

# BtbN LGPL static FFmpeg — third-party prebuilt static-linked
# `ffmpeg`/`ffprobe`/`ffplay` binaries from the public CI pipeline at
# https://github.com/BtbN/FFmpeg-Builds/. We ingest only `ffmpeg` +
# `ffprobe` (no `ffplay`); see the `:ffmpeg_layer_*` `tar()` rules in
# `src/BUILD.bazel`.
#
# Why third-party rather than Debian's `ffmpeg`: Debian's `ffmpeg`
# package transitively pulls libsdl2 / libxv1 / libxext6 (~500 MiB) for
# ffplay's GPU video sink. The DSP stack only invokes `ffprobe` (via
# dsp-ingest's `docker run --entrypoint ffprobe daschswiss/sipi …` for
# video metadata) and never the GUI sinks; the static LGPL build is
# self-contained (no shared-lib closure to worry about) and ships at
# ~70 MiB for both binaries combined. License-clean: AGPL-licensed sipi
# invokes ffprobe as a subprocess (process boundary), so the LGPL+sipi
# combination has no viral linking concern.
#
# Pinning: the `autobuild-YYYY-MM-DD-HH-MM` tag freezes the build
# artifacts (immutable on GitHub once published). The `n8.1.1-…-lgpl-8.1`
# asset name pins to FFmpeg's stable 8.1.1 source tag, not the
# rolling-master nightly. Bumping means picking a newer
# `autobuild-…` release that publishes a newer stable-tag asset
# (look for `n8.X.Y-…-lgpl-8.X.tar.xz`) and refreshing both URLs +
# both sha256 sums.
http_archive(
    name = "ffmpeg_static_linux_amd64",
    build_file_content = """\
filegroup(
    name = "binaries",
    srcs = [
        "bin/ffmpeg",
        "bin/ffprobe",
    ],
    visibility = ["//visibility:public"],
)

exports_files([
    "bin/ffmpeg",
    "bin/ffprobe",
])
""",
    sha256 = "14cd4d032ac0bf5e85844305049b19949cf8a5f136d7d6c6d07f6037182fa877",
    strip_prefix = "ffmpeg-n8.1.1-linux64-lgpl-8.1",
    url = "https://github.com/BtbN/FFmpeg-Builds/releases/download/autobuild-2026-05-08-13-23/ffmpeg-n8.1.1-linux64-lgpl-8.1.tar.xz",
)

http_archive(
    name = "ffmpeg_static_linux_arm64",
    build_file_content = """\
filegroup(
    name = "binaries",
    srcs = [
        "bin/ffmpeg",
        "bin/ffprobe",
    ],
    visibility = ["//visibility:public"],
)

exports_files([
    "bin/ffmpeg",
    "bin/ffprobe",
])
""",
    sha256 = "47cdca89bcde8ad15fb0896de50450f5cd373f572c2f48cb5e866a0a6437d7f8",
    strip_prefix = "ffmpeg-n8.1.1-linuxarm64-lgpl-8.1",
    url = "https://github.com/BtbN/FFmpeg-Builds/releases/download/autobuild-2026-05-08-13-23/ffmpeg-n8.1.1-linuxarm64-lgpl-8.1.tar.xz",
)

# ── Test-only deps ────────────────────────────────────────────────────────
# Pinned to 1.17.0.bcr.2 because transitive deps (`aspect_bazel_lib` and the
# rules under it) already pull in `googletest@1.17.0`; declaring an older
# version here triggers a `--check_direct_dependencies` warning under
# Bazel 9's MVS resolver. 1.17.0 is API-compatible with the 1.16.x line
# (gtest's API has been stable across 1.1x).
# The `dev_dependency = True` flag keeps it out of the runtime build graph
# so production targets in `//src` and `//shttps` cannot accidentally take
# a transitive dep on test infrastructure.
bazel_dep(name = "googletest", version = "1.17.0.bcr.2", dev_dependency = True)

# ── LLVM toolchain — hermetic, LLVM 19.1.7, libc++ ─────────────────────────
#
# Linux libc++ ships in the LLVM tarball built against glibc, so it still
# needs sysroot headers and runtime libs at build time. Without an explicit
# sysroot the build silently links against the host's glibc — non-hermetic.
# Chromium's debian sysroot tarballs are the canonical fix (research-doc §4).
#
# The `stdlib` map pins libc++ on Linux to avoid cc_toolchain_config.bzl
# silently demoting "builtin-libc++" to "stdc++" under cross-compile (research
# §4 footnote). Y+8's eventual cross-compile work expects libc++; pin
# explicitly now to prevent the silent swap.
#
# darwin entries deliberately omitted: setting stdlib="libc++" appends
# `-l:libc++.a -l:libc++abi.a` to LDFLAGS (Linux-style static archive
# linkage), which ld64.lld rejects ("library not found for -l:libc++.a")
# because macOS only ships dynamic libc++ in the SDK. On darwin the
# toolchain default already uses libc++ via the Xcode CLT SDK; pinning is
# unnecessary and breaks the build.
sysroot = use_repo_rule("@toolchains_llvm//toolchain:sysroot.bzl", "sysroot")

# Chromium's debian-bullseye sysroots — pulled from the canonical
# `sysroots.json` at:
#   https://chromium.googlesource.com/chromium/src/+/refs/heads/main/build/linux/sysroot_scripts/sysroots.json
# The URL is `{base}/{Sha256Sum}` per Chromium's `install-sysroot.py`
# (the sha doubles as the path component AND the integrity check). Bumping
# bullseye → bookworm later means re-running:
#   curl -s https://chromium.googlesource.com/chromium/src/+/refs/heads/main/build/linux/sysroot_scripts/sysroots.json?format=TEXT | base64 -d | jq '.bookworm_amd64'
# and copying the `Sha256Sum` field into both `urls` and `sha256` below.
sysroot(
    name = "sysroot_linux_x86_64",
    sha256 = "52d61d4446ffebfaa3dda2cd02da4ab4876ff237853f46d273e7f9b666652e1d",
    urls = ["https://commondatastorage.googleapis.com/chrome-linux-sysroot/52d61d4446ffebfaa3dda2cd02da4ab4876ff237853f46d273e7f9b666652e1d"],
)

sysroot(
    name = "sysroot_linux_aarch64",
    sha256 = "c7176a4c7aacbf46bda58a029f39f79a68008d3dee6518f154dcf5161a5486d8",
    urls = ["https://commondatastorage.googleapis.com/chrome-linux-sysroot/c7176a4c7aacbf46bda58a029f39f79a68008d3dee6518f154dcf5161a5486d8"],
)

llvm = use_extension("@toolchains_llvm//toolchain/extensions:llvm.bzl", "llvm")
llvm.toolchain(
    name = "llvm_toolchain",
    cxx_standard = {"": "c++23"},
    llvm_version = "19.1.7",
    stdlib = {
        "linux-x86_64": "libc++",
        "linux-aarch64": "libc++",
    },
)
llvm.sysroot(
    name = "llvm_toolchain",
    label = "@sysroot_linux_x86_64//sysroot",
    targets = ["linux-x86_64"],
)
llvm.sysroot(
    name = "llvm_toolchain",
    label = "@sysroot_linux_aarch64//sysroot",
    targets = ["linux-aarch64"],
)

# ── Fuzz toolchain — libc++, fuzz-platform routing only ───────────────────
#
# `--config=fuzz` is platform-pinned by the `bazel-build-fuzz` /
# `bazel-run-fuzz` justfile recipes:
#   * linux-x86_64 → `//tools/fuzz:linux_x86_64_fuzz` (this toolchain wins
#     via `extra_target_compatible_with(fuzz_enabled)` + first-registered
#     order).
#   * darwin-aarch64 → `//tools/fuzz:darwin_aarch64_fuzz` (the default
#     `llvm_toolchain` wins for darwin entries here because this toolchain
#     does not register a darwin sysroot — toolchain resolution falls
#     through. macOS Apple SDK + libc++ is the libFuzzer ABI on darwin
#     anyway).
#
# Modern libFuzzer (LLVM ≥ 16) ships its own private libc++ runtime, so
# the harness binary's stdlib choice does not affect libFuzzer linkage.
# Linux fuzz uses libc++ — same as the default `llvm_toolchain` — so the
# LLVM-bundled libc++ archive ships with the toolchain and links cleanly.
# An earlier draft pinned `stdlib = "stdc++"` for parity with the deleted
# `pkgs.llvmPackages_19.stdenv` Nix variant; that broke the build because
# the Chromium debian-bullseye sysroot does not include `libstdc++.a`,
# so toolchains_llvm's `-l:libstdc++.a` was unsatisfiable at link time.
#
# `llvm.toolchain_root` shares `@llvm_toolchain_llvm` — Bazel does not
# re-fetch the LLVM tarball for the fuzz toolchain. Verified post-build
# by inspecting `bazel-out/external/` (only one `llvm_toolchain_llvm` dir).
#
# `extra_target_compatible_with(constraints = [fuzz_enabled])` (no
# `targets =` filter, so it applies to ALL platform entries this toolchain
# auto-registers for) makes this toolchain match ONLY platforms that
# carry `fuzz_enabled`. Without the broad scoping, the auto-created darwin
# entries would silently match plain darwin builds too. The second
# toolchain is now functionally identical to `llvm_toolchain` on linux —
# kept distinct as routing infrastructure for any future fuzz-only
# toolchain customisation.
llvm.toolchain(
    name = "llvm_toolchain_fuzz",
    cxx_standard = {"": "c++23"},
    llvm_version = "19.1.7",
    stdlib = {"linux-x86_64": "libc++"},
)
llvm.toolchain_root(
    name = "llvm_toolchain_fuzz",
    # Must be a fully-qualified label — the rule's impl splits on `:` and
    # only the package portion is consumed. A bare `@llvm_toolchain_llvm`
    # (no `//:target`) fails validation.
    label = "@llvm_toolchain_llvm//:BUILD",
)
llvm.sysroot(
    name = "llvm_toolchain_fuzz",
    label = "@sysroot_linux_x86_64//sysroot",
    targets = ["linux-x86_64"],
)
llvm.extra_target_compatible_with(
    name = "llvm_toolchain_fuzz",
    constraints = ["//tools/fuzz:fuzz_enabled"],
)
use_repo(llvm, "llvm_toolchain", "llvm_toolchain_llvm")
use_repo(llvm, "llvm_toolchain_fuzz")

# Registration order matters: when both `llvm_toolchain_fuzz` and
# `llvm_toolchain` match a target platform (e.g. linux_x86_64_fuzz, where
# the default toolchain's [os:linux, cpu:x86_64] is a subset of the
# platform's [os:linux, cpu:x86_64, fuzz_enabled]), Bazel picks the
# first-registered. Register `llvm_toolchain_fuzz` first so it wins on
# fuzz_enabled platforms; non-fuzz builds skip past it (their platform
# lacks fuzz_enabled) and fall through to `llvm_toolchain`.
register_toolchains("@llvm_toolchain_fuzz//:all")

register_toolchains("@llvm_toolchain//:all")

# ── Rust toolchain + Crate Universe ─────────────────────────────────────────
#
# `rules_rust` produces one `rust_test` target per `tests/<name>.rs` file
# under `//test/e2e-rust:`, mirroring Cargo's "one binary per `[[test]]`"
# semantics.
#
# **Registration ordering is load-bearing.** `cargo_build_script` rules
# (run during Crate Universe materialisation for every `*-sys` crate)
# resolve `cc` from the registered cc_toolchain at materialisation time.
# The LLVM toolchain blocks above MUST appear before the Rust extension —
# otherwise build scripts silently pick up the host `cc` and produce
# non-hermetic artifacts.
bazel_dep(name = "rules_rust", version = "0.70.0")

rust = use_extension("@rules_rust//rust:extensions.bzl", "rust")
rust.toolchain(
    edition = "2021",
    # 1.88+ required: transitive `time-macros` crate uses
    # `proc_macro_span` (stabilised in 1.88). Edition 2024 (1.85+) is
    # also required by the transitive `pxfm` crate. `test/e2e-rust/
    # Cargo.toml` itself stays on edition 2021 — the transitive bumps
    # are invisible to first-party code.
    versions = ["1.89.0"],
)
use_repo(rust, "rust_toolchains")
register_toolchains("@rust_toolchains//:all")

# `crate.from_cargo` is lazy resolution from `Cargo.lock` — the canonical
# default since rules_rust 0.59. `crates_vendor` (vendored sources in-tree)
# is reserved for offline CI scenarios that don't apply here.
#
# Repin via:  CARGO_BAZEL_REPIN=1 bazelisk fetch @crates//:all
crate = use_extension("@rules_rust//crate_universe:extensions.bzl", "crate")
crate.from_cargo(
    name = "crates",
    cargo_lockfile = "//test/e2e-rust:Cargo.lock",
    manifests = ["//test/e2e-rust:Cargo.toml"],
)

# `aws-lc-sys` is intentionally NOT in the dep graph — its cmake-based
# build script panics inside Bazel actions ("rust_wrapper.h is not a
# directory"). `test/e2e-rust/Cargo.toml` uses `jsonwebtoken`'s
# `rust_crypto` (pure-Rust) backend instead. The only `tests/`
# consumer is `security.rs`, which uses HS256 — a symmetric algorithm
# not affected by the backend choice. If a future test needs RSA/ECDSA
# JWT verification, `rust_crypto` covers both via `rsa` + `p256`/`p384`.
use_repo(crate, "crates")

# ── Kakadu (proprietary, GitHub-release-gated) ─────────────────────────────
# Custom repository_rule mirroring today's Nix FOD auth UX 1:1 — shells out
# to `gh release download` instead of `http_archive` + `auth_patterns` (the
# latter requires `~/.netrc`, which `gh` does not populate).
kakadu_extension = use_extension("//bazel:kakadu_extension.bzl", "kakadu_extension")
use_repo(kakadu_extension, "kakadu")

# ── ApprovalTests.cpp (single-header release, no BCR module) ───────────────
# `bazel/approvaltests_cpp.bzl` downloads the .hpp file released by the
# upstream project and exposes it as `cc_library(name = "approval_tests")`.
approvaltests_cpp = use_repo_rule("//bazel:approvaltests_cpp.bzl", "approvaltests_cpp")

approvaltests_cpp(
    name = "approvaltests_cpp",
    sha256 = "c00f6390b81d9924dc646e9d32b61e1e09abda106c13704f714ac349241bb9ff",
    url = "https://github.com/approvals/ApprovalTests.cpp/releases/download/v.10.13.0/ApprovalTests.v.10.13.0.hpp",
)

# ── Third-party C/C++ libs (rules_foreign_cc) ──────────────────────────────
# URLs and SHA256s are the single source of truth.
#
# Each archive's `build_file = "//bazel:all_content.BUILD.bazel"` exposes
# the raw source tree as `@<lib>//:all_srcs`; the foreign_cc rule lives
# under `//ext/<lib>:<lib>` and consumes that filegroup.
#
# `http_archive` itself is bound near the top of this file (alongside
# the FFmpeg static pull). One binding services every consumer.

# bzip2 — gitlab archive
http_archive(
    name = "bzip2",
    build_file = "//bazel:all_content.BUILD.bazel",
