#
# ignore object files and libraries
#
*.[oa]

#
# ignore executable
#
sipi

#
# other files to be ignored
#
.DS_Store
*~
*.pyc
.idea/
/.vscode
/include/SipiConfig.h
/include/SipiVersion.h
sipi.log*
/extsrcs/
.direnv/

target
__pycache__/
doc/
_build/
.pytest_cache
/venv/

#
# Cmake things to be ignored
#
lib
local
build/
build-linux/
build-mac/
build-fuzz/
cmake-build-debug/
cmake-build-debug-remote/
cmake-build-debug-inside-docker/
cmake-build-dockerdebug/
cmake-build-relwithdebinfo-inside-docker/
cmake-build-relwithdebinfo-nix-develop/
# ignore runtime cache directory
/cache/
# test-generated cache directories and configs
test/_test_data/cache/
test/_test_data/cache_test_*/
test/_test_data/config/sipi.cache-test-*.lua

#ignore ICC headers
*_icc.h
/images/
/server/admin/
icc.zip

# ignore test results
/Testing
/test/nginx/logs/error.log
/site
/test/e2e/diff.tif

# ignore coverage
/coverage
/coverage.info
*.gcov

# Nix build output symlinks (emitted by `just nix-*` / `nix build`)
/result
/result-*

# Kakadu is proprietary — injected by CI from dsp-ci-assets
vendor/v8_4_1-*.zip
vendor/v8_5-*.zip

# Git LFS hooks (auto-installed by `git lfs install`; configured via
# `core.hooksPath = .githooks` in the dev shell). Per-developer state,
# not project source. The project's own pre-commit hook is tracked.
.githooks/post-checkout
.githooks/post-commit
.githooks/post-merge
.githooks/pre-push

# Claude Code
.claude/worktrees/
.claude/settings.local.json
