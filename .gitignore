#
# ignore object files and libraries
#
*.[oa]

#
# ignore executable
#
sipi

#
# other files to be ignored
#
.DS_Store
*~
*.pyc
.idea/
/.vscode
/include/SipiConfig.h
/include/SipiVersion.h
sipi.log*
/extsrcs/
.direnv/

target
__pycache__/
doc/
_build/
.pytest_cache
/venv/

#
# Cmake things to be ignored
#
lib
local
build/
build-linux/
build-mac/
build-fuzz/
cmake-build-debug/
cmake-build-debug-remote/
cmake-build-debug-inside-docker/
cmake-build-dockerdebug/
cmake-build-relwithdebinfo-inside-docker/
cmake-build-relwithdebinfo-nix-develop/
# ignore runtime cache directory
/cache/
# test-generated cache directories and configs
test/_test_data/cache/
test/_test_data/cache_test_*/
test/_test_data/config/sipi.cache-test-*.lua
test/_test_data/config/sipi.tracing-test.lua

#ignore ICC headers
*_icc.h
/images/
/server/admin/
icc.zip

# ignore test results
/Testing
/test/nginx/logs/error.log
/site
/test/e2e/diff.tif

# ignore coverage
/coverage
/coverage.info
*.gcov

# Bazel output-base symlinks at the workspace root (bazel-bin, bazel-out,
# bazel-testlogs, bazel-<workspace>). MODULE.bazel.lock is committed.
/bazel-*
# Per-developer Bazel overrides — not project source.
/user.bazelrc
# rust-analyzer project model, generated by `just bazel-rust-project`
# (rules_rust gen_rust_project). Holds machine-absolute Bazel paths — generated
# per checkout, never committed.
/rust-project.json
# Debug-symbol file surfaced by `just bazel-docker-extract-debug <arch>` for
# the Sentry upload; a large, ephemeral per-arch artifact, never committed.
/sipi-*.debug

# Claude Code
.claude/worktrees/
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Terraform / OpenTofu (infra/). The provider lock (.terraform.lock.hcl) IS
# tracked; the local provider cache and any state/backups are not.
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
.terraformrc
terraform.rc
