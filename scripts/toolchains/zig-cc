#!/bin/sh
# Wrapper script for using "zig cc" as CMAKE_C_COMPILER.
#
# CMake requires CMAKE_C_COMPILER to be a single executable path.
# This wrapper solves the "two-word command" problem by delegating to "zig cc".
#
# When cross-compiling, cmake/zig-toolchain.cmake writes the target triple
# to .zig-target next to this script.  The wrapper injects -target
# automatically so ALL consumers (ExternalProject deps, autotools, make)
# get the correct cross-compilation target without forwarding flags.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TARGET_FILE="$SCRIPT_DIR/.zig-target"

if [ -z "$ZIG_TARGET" ] && [ -f "$TARGET_FILE" ]; then
    ZIG_TARGET="$(cat "$TARGET_FILE")"
fi

if [ -n "$ZIG_TARGET" ]; then
    exec zig cc -target "$ZIG_TARGET" "$@"
else
    exec zig cc "$@"
fi
