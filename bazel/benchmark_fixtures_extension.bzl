"""Module extension that wires the benchmark fixture archive into MODULE.bazel.

Same thinnest-viable wiring as `kakadu_extension.bzl`: the single
`sipi_bench_fixtures` repo invokes `gh_release_archive` with the values
pinned here. The archive is generated by `tools/benchmark/generate_fixtures.sh`
(which documents the full provenance chain) and hosted as a release asset on
dasch-swiss/dsp-ci-assets next to the Kakadu archives. Bumping the fixture
set means cutting a new release tag and editing this file only.
"""

load("//bazel:gh_release.bzl", "gh_release_archive")

def _benchmark_fixtures_extension_impl(_ctx):
    gh_release_archive(
        name = "sipi_bench_fixtures",
        tag = "sipi-bench-fixtures-v1",
        asset = "sipi-bench-fixtures-v1.tar.zst",
        repo = "dasch-swiss/dsp-ci-assets",
        sha256 = "9ce90bb3d1cd7ecf7a5ad27efd3cd0fb03f97a3145d4f4f1f9f85fea9869bd3e",
        strip_prefix = "sipi-bench-fixtures-v1",
        build_file = "//bazel:benchmark_fixtures.BUILD.bazel",
    )

benchmark_fixtures_extension = module_extension(
    implementation = _benchmark_fixtures_extension_impl,
)
