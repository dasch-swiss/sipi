# Platform definitions for Sipi.
#
# Bazel resolves toolchains and `select()` branches against constraints; these
# platforms compose the standard `@platforms//os:*` and `@platforms//cpu:*`
# constraints into the three (os, cpu) pairs Sipi supports per CLAUDE.md's
# build-completeness invariant: darwin-aarch64, linux-x86_64, linux-aarch64.

package(default_visibility = ["//visibility:public"])

platform(
    name = "linux_x86_64",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
    ],
    # The NativeLink RBE worker is x86_64-linux. When the arm64/darwin CI legs
    # cross-compile here (exec = this platform), the scheduler matches the worker
    # on this property. Mirrors --remote_default_exec_properties=cpu_arch=x86_64 in
    # CI; keep minimal (don't add OSFamily unless the worker advertises it, or the
    # scheduler reports "no matching worker"). Inert for local/non-remote builds.
    exec_properties = {
        "cpu_arch": "x86_64",
    },
)

platform(
    name = "linux_aarch64",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:aarch64",
    ],
)

platform(
    name = "darwin_aarch64",
    constraint_values = [
        "@platforms//os:macos",
        "@platforms//cpu:aarch64",
    ],
)

# Config settings for per-platform `select()` branches in BUILD files
# (e.g. the native cc_library deps' per-arch SIMD copts/defines).
# `platform()` cannot be used in `select()`; `config_setting` can.
config_setting(
    name = "is_linux_x86_64",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
    ],
)

config_setting(
    name = "is_linux_aarch64",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:aarch64",
    ],
)

config_setting(
    name = "is_darwin_aarch64",
    constraint_values = [
        "@platforms//os:macos",
        "@platforms//cpu:aarch64",
    ],
)
